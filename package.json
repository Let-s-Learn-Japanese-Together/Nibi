{
  "name": "discord-interaction-bot",
  "version": "0.1.0",
  "description": "Discord bot leveraging interaction endpoints with Hono",
  "main": "dist/index.js",
  "scripts": {
    "build": "npx tsc",
    "dev:vercel": "npx vercel dev",
    "dev:wrangler": "npx wrangler dev --local",
    "deploy": "npx vercel --prod",
    "deploy:wrangler": "npx wrangler deploy",
    "register-commands": "npx ts-node src/register-commands.ts",
    "format": "npx prettier --write .",
    "lint": "npx eslint src --ext .ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.0.0",
    "discord-interactions": "^1.3.0",
    "dotenv": "^17.3.1",
    "ejs": "^5.0.1",
    "google-translate-api-x": "^10.7.2",
    "google-tts-api": "^2.0.2",
    "hono": "^3.1.0",
    "kuroshiro": "^1.2.0",
    "kuroshiro-analyzer-kuromoji": "^1.1.0",
    "nodemailer": "^8.0.1",
    "vercel": "^50.28.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/ejs": "^3.1.5",
    "@types/eslint-plugin-security": "^3.0.1",
    "@types/nodemailer": "^7.0.11",
    "eslint": "^10.0.3",
    "eslint-plugin-security": "^4.0.0",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "ts-node": "^10.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.56.1",
    "wrangler": "^4.71.0"
  }
}
